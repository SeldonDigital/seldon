{
  "name": "seldon",
  "version": "0.0.0",
  "private": true,
  "description": "Seldon · Core, Editor, and Factory",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace @seldon/editor",
    "ollama:kill": "pkill -f 'ollama serve' || true",
    "build": "npm run build --workspace @seldon/editor",
    "start": "npm run start --workspace @seldon/editor",
    "lint": "npm run lint --workspace @seldon/editor",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,js,mjs}\"",
    "quality": "npm run format:check && npm run quality --workspace @seldon/editor",
    "format": "node scripts/format.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dev:vue": "npm run dev --workspace @seldon/editor-vue",
    "build:vue": "npm run build --workspace @seldon/editor-vue",
    "start:vue": "npm run start --workspace @seldon/editor-vue",
    "lint:vue": "npm run lint --workspace @seldon/editor-vue",
    "quality:vue": "npm run quality --workspace @seldon/editor-vue",
    "export:seldon:vue": "npm run export:seldon --workspace @seldon/editor-vue"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeldonDigital/seldon.git"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN ./license/noncommercial/LICENSE.md",
  "bugs": {
    "url": "https://github.com/SeldonDigital/seldon/issues"
  },
  "homepage": "https://github.com/SeldonDigital/seldon#readme",
  "workspaces": [
    "packages/editor",
    "packages/editor-vue",
    "packages/core",
    "packages/factory",
    "packages/ai"
  ],
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "volta": {
    "node": "22.18.0"
  }
}
