{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noErrorTruncation": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["vite/client"],
    "paths": {
      "@app/*": ["./app/*"],
      "@seldon/editor/*": ["../../packages/editor/*"],
      "@seldon/components/*": ["./seldon/*"],
      "@seldon/core/*": ["../../packages/core/*"],
      "@seldon/factory/*": ["../../packages/factory/*"],
      "@seldon/ai": ["../../packages/ai/index.ts"],
      "@seldon/ai/*": ["../../packages/ai/*"]
    },
    "target": "ES2017"
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
