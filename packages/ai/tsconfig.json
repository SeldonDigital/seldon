{
  "compilerOptions": {
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "target": "ES2021",
    "paths": {
      "@seldon/core/*": ["../core/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
