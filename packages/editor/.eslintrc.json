{
  "extends": ["plugin:@typescript-eslint/strict", "next/core-web-vitals"],
  "ignorePatterns": ["**/_components/seldon/*"],
  "rules": {
    "@next/next/no-img-element": "off",
    "@next/next/no-page-custom-font": "off",
    "@typescript-eslint/no-non-null-assertion": "off",
    "no-console": [
      "warn",
      {
        "allow": [
          "warn",
          "error",
          "info",
          "dir",
          "group",
          "groupCollapsed",
          "groupEnd"
        ]
      }
    ],
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ]
  }
}
